{
  "name": "taller_products",
  "version": "1.0.0",
  "description": "Modulo para el taller de AWS con Serverless hecho para manejar las peticiones de los productos ",
  "keywords": [
    "AWS",
    "Node.js",
    "Serverless"
  ],
  "license": "ISC",
  "author": "Miguel Mejía",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "deploy:dev": "serverless deploy --stage develop --aws-profile serverless_user_personal",
    "remove:dev": "serverless remove --stage develop --aws-profile serverless_user_personal",
    "deploy:prod": "serverless deploy --stage prod --aws-profile serverless_user_personal",
    "remove:prod": "serverless remove --stage prod --aws-profile serverless_user_personal"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.9.1",
    "aws-lambda": "^1.0.7",
    "serverless": "^4.36.1",
    "serverless-localstack": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/lib-dynamodb": "^3.1049.0",
    "uuid": "^14.0.0"
  }
}
